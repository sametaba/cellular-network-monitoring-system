# ── Database ───────────────────────────────────────────────────────────────────
# Local development:
#   DATABASE_URL=postgresql+asyncpg://postgres:admin@localhost:5432/cellular_monitor
# Docker Compose (service name 'db' resolves inside the network):
#   DATABASE_URL=postgresql+asyncpg://postgres:admin@db:5432/cellular_monitor
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/cellular_monitor

# ── App ────────────────────────────────────────────────────────────────────────
# Production: APP_ENV=production  APP_DEBUG=False  (these are the safe defaults)
# Development: APP_ENV=development  APP_DEBUG=True
APP_ENV=production
APP_DEBUG=False
APP_TITLE="AI Assisted Cellular Network Monitor"
APP_VERSION=0.1.0

# ── CORS ───────────────────────────────────────────────────────────────────────
# PRODUCTION: Set to the exact frontend origin — NEVER use "*" in production.
#   CORS_ORIGINS=https://your-domain.com
# DEVELOPMENT: Use "*" or your Vite dev server URL.
#   CORS_ORIGINS=http://localhost:5173
CORS_ORIGINS=https://your-domain.com
