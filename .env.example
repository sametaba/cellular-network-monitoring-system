# PostgreSQL connection (asyncpg driver required)
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/cellular_monitoring

# App settings
APP_ENV=development
APP_DEBUG=True
APP_TITLE="AI Assisted Cellular Network Monitor"
APP_VERSION=0.1.0

# CORS — use "*" in development, exact URL in production
# e.g. CORS_ORIGINS=http://localhost:5173,https://your-domain.com
CORS_ORIGINS=*
